{
  "name": "stash-app",
  "private": true,
  "version": "0.1.15",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:cli && tsc && vite build",
    "build:cli": "cargo build --manifest-path src-tauri/Cargo.toml -p stash-cli --release",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
