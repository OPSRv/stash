{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Stash windows",
  "windows": ["popup", "settings", "downloads"],
  "permissions": [
    "core:default",
    "opener:default",
    "global-shortcut:default",
    "store:default",
    "autostart:default",
    "clipboard-manager:allow-read-text",
    "opener:allow-reveal-item-in-dir"
  ]
}
