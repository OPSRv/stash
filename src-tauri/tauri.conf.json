{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stash",
  "version": "0.1.9",
  "identifier": "com.opsrv.stash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "popup",
        "title": "Stash",
        "width": 920,
        "height": 640,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "shadow": false
      },
      {
        "label": "voice-popup",
        "url": "voice.html",
        "title": "Stash Voice",
        "width": 480,
        "height": 360,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: https://asset.localhost ipc: http://ipc.localhost data: blob: https:; media-src 'self' asset: https://asset.localhost blob: data: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https: wss: data: blob: http://127.0.0.1:*; frame-src 'self' https:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**", "$HOME/Movies/Stash/**", "$HOME/Movies/Stash/.thumbs/**", "$VIDEO/**", "$TEMP/Stash/**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [
        "sherpa-libs/libsherpa-onnx-c-api.dylib",
        "sherpa-libs/libonnxruntime.1.17.1.dylib"
      ]
    },
    "resources": {
      "target/release/stash": "bin/stash"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OPSRv/stash/releases/download/nightly/latest.json"
      ],
      "pubkey": ""
    }
  }
}
